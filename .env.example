# DATABASE & CORE
# -----------------------------------------------------------------------------
PORT=5000
DATABASE_URL="file:./dev.db"
JWT_SECRET=your_super_secret_jwt_key_here
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

