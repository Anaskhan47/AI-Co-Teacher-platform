{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/curriculum/metadata",
      "dest": "/api/curriculum/metadata.ts"
    },
    {
      "src": "/api/curriculum/boards",
      "dest": "/api/curriculum/boards.ts"
    },
    {
      "src": "/api/dashboard/stats",
      "dest": "/api/dashboard/stats.ts"
    },
    {
      "src": "/api/students/roster",
      "dest": "/api/students/roster.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
