{
  "version": 2,
  "buildCommand": "prisma generate --schema=backend/src/prisma/schema.prisma && vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path]"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
